# ====================================================================
# 信号生成函数
# 根据策略 IR 中的条件和动作节点生成买卖信号
# 买入信号：布尔 Series，True 表示在该 K 线买入
# 卖出信号：布尔 Series，True 表示在该 K 线卖出
# ====================================================================
def generate_signals(df: pd.DataFrame, params: dict) -> tuple:
    """
    根据策略 IR 生成交易信号。

    Args:
        df: 包含指标列的 DataFrame。
        params: 策略参数字典。

    Returns:
        tuple: (entries, exits) 两个布尔 Series。
    """
    entries = pd.Series(False, index=df.index)
    exits = pd.Series(False, index=df.index)

    # 买入条件（根据 StrategyIR 解析生成）
    {% for cond in entry_conditions %}
    # 买入条件 {{ loop.index }}：{{ cond }}
    condition_{{ loop.index }} = {{ cond }}
    entries = entries | condition_{{ loop.index }}
    {% else %}
    # 默认买入条件：无
    entries = pd.Series(False, index=df.index)
    {% endfor %}

    # 卖出条件（根据 StrategyIR 解析生成）
    {% for cond in exit_conditions %}
    # 卖出条件 {{ loop.index }}：{{ cond }}
    condition_exit_{{ loop.index }} = {{ cond }}
    exits = exits | condition_exit_{{ loop.index }}
    {% else %}
    # 默认卖出条件：无
    exits = pd.Series(False, index=df.index)
    {% endfor %}

    # 防止同时出现买入和卖出信号（卖出优先）
    entries = entries & (~exits)

    return entries, exits


# ====================================================================
# 回测执行函数
# 使用 vectorbt 的 Portfolio.from_signals 进行向量化回测
# ====================================================================
def run_backtest(
    df: pd.DataFrame, entries: pd.Series, exits: pd.Series, config: dict
) -> vbt.Portfolio:
    """
    执行向量化回测。

    Args:
        df: 行情数据 DataFrame。
        entries: 买入信号布尔 Series。
        exits: 卖出信号布尔 Series。
        config: 回测配置字典。

    Returns:
        vbt.Portfolio: 回测结果对象。
    """
    close = df["close"]

    # 仓位管理：根据配置选择固定金额或百分比
    size = config.get("size", 0.1)  # 默认使用 10% 资金
    if config.get("position_sizing") == "fixed":
        size = config.get("fixed_amount", 100000)  # 固定金额

    # 运行回测
    portfolio = vbt.Portfolio.from_signals(
        close=close,
        entries=entries,
        exits=exits,
        size=size,
        slippage=config.get("slippage", SLIPPAGE),
        fees=config.get("commission_rate", COMMISSION_RATE),
        init_cash=config.get("initial_capital", INITIAL_CAPITAL),
        freq=config.get("timeframe", TIMEFRAME),
    )

    return portfolio


# ====================================================================
# 性能分析函数
# 输出回测的核心性能指标：总收益、夏普比率、最大回撤等
# ====================================================================
def analyze_performance(portfolio: vbt.Portfolio) -> dict:
    """
    分析回测性能并返回关键指标。

    Args:
        portfolio: vectorbt 回测结果对象。

    Returns:
        dict: 包含性能指标的字典。
    """
    stats = portfolio.stats()

    # 提取关键指标
    metrics = {
        "total_return": stats.get("Total Return [%]", 0),
        "sharpe_ratio": stats.get("Sharpe Ratio", 0),
        "max_drawdown": stats.get("Max Drawdown [%]", 0),
        "win_rate": stats.get("Win Rate [%]", 0),
        "avg_win": stats.get("Avg Winning Trade [%]", 0),
        "avg_loss": stats.get("Avg Losing Trade [%]", 0),
        "total_trades": stats.get("Total Trades", 0),
    }

    return metrics


