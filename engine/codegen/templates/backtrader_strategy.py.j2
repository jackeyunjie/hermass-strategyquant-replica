# ====================================================================
def main():
    """
    策略主入口函数。
    执行完整的事件驱动回测流程并打印性能指标。
    """
    print(f"策略名称: {STRATEGY_NAME}")
    print(f"策略 ID: {STRATEGY_ID}")
    print(f"描述: {DESCRIPTION}")
    print("-" * 60)

    # 1. 加载数据
    symbol = "000001.SZ"  # 示例：平安银行（请替换为真实代码）
    start = "2020-01-01"
    end = "2024-01-01"
    df = load_data(symbol, start, end)
    print(f"数据加载完成：{len(df)} 条 K 线")

    # 2. 执行回测
    config = {
        "slippage": SLIPPAGE,
        "commission_rate": COMMISSION_RATE,
        "initial_capital": INITIAL_CAPITAL,
        "position_sizing": POSITION_SIZING,
        "timeframe": TIMEFRAME,
    }
    cerebro, results = run_backtest(df, config)
    print("回测执行完成")

    # 3. 分析性能
    metrics = analyze_performance(results)
    print("\n===== 回测性能报告 =====")
    for key, value in metrics.items():
        print(f"  {key}: {value}")
    print("=" * 60)

    # 4. 绘制图表（可选）
    # cerebro.plot()


if __name__ == "__main__":
    main()
