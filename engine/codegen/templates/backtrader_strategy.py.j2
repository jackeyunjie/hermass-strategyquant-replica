# ====================================================================
# 策略类定义
# 继承 bt.Strategy，在 __init__ 中初始化指标，在 next() 中执行交易逻辑
# ====================================================================
class {{ strategy_name | replace(' ', '_') | replace('-', '_') }}Strategy(bt.Strategy):
    """
    自动生成的 backtrader 策略：{{ description }}
    策略 ID：{{ strategy_id }}
    生成时间：{{ now }}
    """

    # 策略可调参数（从 StrategyIR 的 VALUE 和 PARAM 节点解析）
    params = (
        {% if variables %}
        {% for key, value in variables.items() %}
        ('{{ key }}', {{ value | tojson }}),
        {% endfor %}
        {% else %}
        ('lookback', 20),
        ('threshold', 0.02),
        {% endif %}
    )

    def __init__(self):
        """
        初始化技术指标。
        在回测开始前一次性计算所有指标值。
        """
        # 记录指标引用，便于在 next() 中访问
        self.indicators_dict = {}

        {% for node_id, ind in indicator_expressions.items() %}
        # 指标：{{ ind.name }}（节点 {{ node_id }}）
        # 参数：{{ ind.params | tojson }}
        self.indicators_dict['{{ ind.var_name }}'] = {{ ind.expr }}
        {% else %}
        # 未检测到指标节点，使用默认 SMA 占位符
        self.sma = bt.indicators.SimpleMovingAverage(self.data.close, period=self.p.lookback)
        {% endfor %}

    def next(self):
        """
        逐 K 线执行交易逻辑。
        backtrader 会在每根 K 线收盘时调用此方法。
        """
        # 获取当前 K 线的数据
        current_close = self.data.close[0]
        current_open = self.data.open[0]
        current_high = self.data.high[0]
        current_low = self.data.low[0]
        current_volume = self.data.volume[0]

        # 买入条件（根据 StrategyIR 解析生成）
        {% for cond in entry_conditions %}
        # 买入条件 {{ loop.index }}：{{ cond }}
        {% endfor %}
        entry_signal = (
            {% for cond in entry_conditions %}
            ({{ cond }}){% if not loop.last %} and {% endif %}
            {% else %}
            False  # 默认无买入条件
            {% endfor %}
        )

        # 卖出条件（根据 StrategyIR 解析生成）
        {% for cond in exit_conditions %}
        # 卖出条件 {{ loop.index }}：{{ cond }}
        {% endfor %}
        exit_signal = (
            {% for cond in exit_conditions %}
            ({{ cond }}){% if not loop.last %} and {% endif %}
            {% else %}
            False  # 默认无卖出条件
            {% endfor %}
        )

        # 交易执行
        if not self.position:
            # 当前无持仓，检查买入信号
            if entry_signal:
                # 根据仓位管理模型计算下单数量
                if POSITION_SIZING == "fixed":
                    size = 1000  # 固定股数
                elif POSITION_SIZING == "percent":
                    cash = self.broker.getcash()
                    size = int(cash * 0.1 / current_close)  # 10% 资金
                else:
                    size = 1000

                self.buy(size=size)
                print(
                    f"买入信号: 日期 {self.data.datetime.date(0)}, "
                    f"价格 {current_close:.2f}, 数量 {size}"
                )
        else:
            # 当前有持仓，检查卖出信号
            if exit_signal:
                self.sell(size=self.position.size)
                print(
                    f"卖出信号: 日期 {self.data.datetime.date(0)}, "
                    f"价格 {current_close:.2f}, 数量 {self.position.size}"
                )

    def notify_order(self, order):
        """
        订单状态通知回调。
        当订单被接受、执行或拒绝时触发。
        """
        if order.status in [order.Submitted, order.Accepted]:
            return

        if order.status in [order.Completed]:
            if order.isbuy():
                print(
                    f"买入成交: 价格 {order.executed.price:.2f}, "
                    f"成本 {order.executed.value:.2f}, "
                    f"佣金 {order.executed.comm:.2f}"
                )
            else:
                print(
                    f"卖出成交: 价格 {order.executed.price:.2f}, "
                    f"成本 {order.executed.value:.2f}, "
                    f"佣金 {order.executed.comm:.2f}"
                )
        elif order.status in [order.Canceled, order.Margin, order.Rejected]:
            print(f"订单失败: {order.status}")


# ====================================================================
# 回测执行函数
# 使用 bt.Cerebro 构建回测引擎并运行
# ====================================================================
def run_backtest(df: pd.DataFrame, config: dict) -> bt.Cerebro:
    """
    使用 backtrader 执行事件驱动回测。

    Args:
        df: 行情数据 DataFrame（用于 bt.feeds.PandasData）。
        config: 回测配置字典。

    Returns:
        bt.Cerebro: 运行后的 Cerebro 实例。
    """
    cerebro = bt.Cerebro()

    # 添加策略
    cerebro.addstrategy({{ strategy_name | replace(' ', '_') | replace('-', '_') }}Strategy)

    # 加载数据（使用 PandasData 直接传入 DataFrame）
    data = bt.feeds.PandasData(
        dataname=df,
        datetime=None,  # 使用 DataFrame 的索引作为日期
        open="open",
        high="high",
        low="low",
        close="close",
        volume="volume",
    )
    cerebro.adddata(data)

    # 设置初始资金
    cerebro.broker.setcash(config.get("initial_capital", INITIAL_CAPITAL))

    # 设置手续费（A 股默认双边万三）
    cerebro.broker.setcommission(
        commission=config.get("commission_rate", COMMISSION_RATE),
        margin=False,
        mult=1.0,
    )

    # 设置滑点（百分比模型）
    cerebro.broker.set_slippage_perc(
        perc=config.get("slippage", SLIPPAGE),
    )

    # 添加分析器（Analyzer）
    cerebro.addanalyzer(bt.analyzers.SharpeRatio, _name="sharpe")
    cerebro.addanalyzer(bt.analyzers.DrawDown, _name="drawdown")
    cerebro.addanalyzer(bt.analyzers.TradeAnalyzer, _name="trades")
    cerebro.addanalyzer(bt.analyzers.Returns, _name="returns")
    cerebro.addanalyzer(bt.analyzers.SQN, _name="sqn")

    # 运行回测
    print(f"初始资金: {cerebro.broker.getvalue():.2f}")
    results = cerebro.run()
    print(f"最终资金: {cerebro.broker.getvalue():.2f}")

    return cerebro, results


# ====================================================================
# 性能分析函数
# 从 backtrader 分析器中提取关键性能指标
# ====================================================================
def analyze_performance(results: list) -> dict:
    """
    从 backtrader 结果中提取性能指标。

    Args:
        results: cerebro.run() 返回的结果列表。

    Returns:
        dict: 包含性能指标的字典。
    """
    if not results:
        return {}

    strat = results[0]
    metrics = {}

    # 夏普比率
    sharpe = strat.analyzers.sharpe.get_analysis()
    metrics["sharpe_ratio"] = sharpe.get("sharperatio", 0)

    # 最大回撤
    drawdown = strat.analyzers.drawdown.get_analysis()
    metrics["max_drawdown"] = drawdown.get("max.drawdown", 0)
    metrics["max_drawdown_len"] = drawdown.get("max.len", 0)

    # 交易分析
    trades = strat.analyzers.trades.get_analysis()
    if trades:
        metrics["total_trades"] = trades.get("total", {}).get("total", 0)
        metrics["win_trades"] = trades.get("won", {}).get("total", 0)
        metrics["lose_trades"] = trades.get("lost", {}).get("total", 0)
        if metrics["total_trades"] > 0:
            metrics["win_rate"] = metrics["win_trades"] / metrics["total_trades"] * 100

    # 收益分析
    returns = strat.analyzers.returns.get_analysis()
    metrics["total_return"] = returns.get("rtot", 0) * 100
    metrics["annual_return"] = returns.get("ravg", 0) * 252 * 100

    # SQN 系统质量数
    sqn = strat.analyzers.sqn.get_analysis()
    metrics["sqn"] = sqn.get("sqn", 0)

    return metrics


